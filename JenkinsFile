pipeline {
    agent any

    stages {

        stage('Install Dependencies') {
            steps {
                sh 'docker run --rm -v $PWD:/app -w /app python:3.12 pip install -r requirements.txt'
            }
        }

        stage('Lint') {
            steps {
                sh 'docker run --rm -v $PWD:/app -w /app python:3.12 pip install pylint'
                sh 'docker run --rm -v $PWD:/app -w /app python:3.12 pylint app || true'
            }
        }

        stage('Test') {
            steps {
                sh 'docker run --rm -v $PWD:/app -w /app python:3.12 pip install pytest'
                sh 'docker run --rm -v $PWD:/app -w /app python:3.12 pytest'
            }
        }

        stage('Build Docker Image') {
            steps {
                sh 'docker build -t devops-flask-app .'
            }
        }

        stage('Run Container') {
            steps {
                sh 'docker run -d -p 5000:5000 devops-flask-app || true'
            }
        }

    }
}